Tabs {
    dock: top;
}
Screen {
    align: center middle;
}
Label {
    margin:1 1;
    width: 100%;
    height: 100%;
    background: $panel;
    border: tall $primary;
    content-align: center middle;
}

close-btn {
        min-width: 6;
        height: 1;
        border: none;
        background: transparent;
        color: $error;
    }
.close-btn:hover { background: $error 20%; }
.tab-header { height: 3; align: right middle; }