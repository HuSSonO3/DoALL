#lorem_container {
    height: 100%;
    width: 100%;
    padding: 1 2;
}

#lorem_toolbar {
    height: 3;
    align: center middle;
}

#lorem_toolbar Label {
    margin: 0 1;
    height: 100%;
    content-align: center middle;
}

#lorem_type {
    width: 18;
}

#lorem_count {
    width: 10;
    margin: 0 1;
}

#lorem_output {
    height: 1fr;
    margin: 1 0;
}

#lorem_bottom {
    height: 3;
    align: center middle;
}
