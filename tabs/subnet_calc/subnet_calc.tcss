#sub_container {
    height: 100%;
    width: 100%;
    padding: 1 2;
    layout: vertical;
}

#sub_title {
    width: 100%;
    text-align: center;
    margin-bottom: 1;
}

#sub_input_row {
    height: auto;
    align: center middle;
    margin-bottom: 1;
}

#sub_input {
    width: 50;
}

#sub_status {
    width: 100%;
    text-align: center;
    margin-bottom: 1;
}

#sub_results {
    height: 1fr;
    border: round $accent;
}
